generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id          String    @id @default(cuid())
  content     String
  priority    Int       @default(5)
  dueDate     DateTime?
  completed   Boolean   @default(false)
  suggestions String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}